// Exemplo de configuracao da API para publicar no Hostgator.
(() => {
  const host = (window.location.hostname || '').toLowerCase();
  const localHosts = new Set(['localhost', '127.0.0.1']);
  const localApiUrl = 'http://localhost:8002/api';
  const productionApiUrl = 'https://sacola-ideias-api.onrender.com/api';

  window.API_URL = localHosts.has(host) ? localApiUrl : productionApiUrl;
})();
